{
    "name": "jeffersongoncalves/laravel-erp-buying",
    "description": "ERP buying — suppliers, RFQs, supplier quotations and purchase orders for the Laravel ERP ecosystem",
    "keywords": [
        "laravel",
        "erp",
        "buying",
        "procurement",
        "purchase-order",
        "supplier"
    ],
    "homepage": "https://github.com/jeffersongoncalves/laravel-erp",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Jefferson Gonçalves",
            "email": "gerson.simao.92@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "jeffersongoncalves/laravel-erp-accounting": "self.version",
        "jeffersongoncalves/laravel-erp-core": "self.version",
        "jeffersongoncalves/laravel-erp-stock": "self.version"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "JeffersonGoncalves\\Erp\\Buying\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JeffersonGoncalves\\Erp\\Buying\\Tests\\": "tests/",
            "JeffersonGoncalves\\Erp\\Buying\\Database\\Factories\\": "database/factories/",
            "JeffersonGoncalves\\Erp\\Core\\Database\\Factories\\": "vendor/jeffersongoncalves/laravel-erp-core/database/factories/",
            "JeffersonGoncalves\\Erp\\Accounting\\Database\\Factories\\": "vendor/jeffersongoncalves/laravel-erp-accounting/database/factories/",
            "JeffersonGoncalves\\Erp\\Stock\\Database\\Factories\\": "vendor/jeffersongoncalves/laravel-erp-stock/database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JeffersonGoncalves\\Erp\\Buying\\ErpBuyingServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/jeffersongoncalves/laravel-erp/issues",
        "source": "https://github.com/jeffersongoncalves/laravel-erp"
    }
}
